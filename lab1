#include "xc.h"
#include "libpic30.h" // biblioteka do opoznienia

int decToGray(int num) {

    return num ^ (num >> 1);
}

void zad1(){
    unsigned char count = 0;
    while(1){
        LATA = count;
        __delay32(1000000);
        count++;
    }
}

void zad2(){
    unsigned char count = 255;
    while(1){
        LATA = count;
        __delay32(1000000);
        count--;
    }
}

void zad3(){
    unsigned char count = 0;
    while(1){
        LATA = decToGray(count);
        __delay32(1000000);
        count++;
    }
}

void zad4(){
    unsigned char count = 255;
    while(1){
        LATA = decToGray(count);
        __delay32(1000000);
        count--;
    }
}

int main(void) {
    
    unsigned char portValue; //deklaracja ?wieca wszystkie diody
    AD1PCFG = 0xFFFF; // port A ustawiony na cyfrowy
    TRISA = 0x0000; // ustawaimy port A na wyjscie
    zad4();
    return -1;
}
